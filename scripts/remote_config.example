# Config for scripts/local/run.sh and scripts/remote/run.sh

# Remote connection (used by scripts/remote/run.sh)
REMOTE_ADDR="ubuntu@62.169.159.125"
REMOTE_PORT="22"
REMOTE_PATH="/tmp/flash_attention_v2_profile"
SSH_KEY_PATH="$HOME/.ssh/id_rsa"
VENV_PATH="/home/ubuntu/fa-venv"

# Pipeline identity
RUN_NAME="remote"
OUTPUT_DIR="profile_results"

# Shape / runtime
PROFILE_SHAPE="16x16x4096x128"
SEQ_LENS="4096,8192"
D_HEADS="128"
BATCH_SIZE="16"
N_HEADS="16"
WARMUPS="10"
REPEATS="50"
DTYPE="fp16"
INPUT_MODE="random"
SEED="1234"
REPLAY_DIR="benchmark/data/replay"
REPLAY_FILE=""
BASELINE="pytorch"

# Task toggles (default: only pybind)
RUN_PYBIND="1"
RUN_OFFICIAL="0"
RUN_PYTORCH="0"
RUN_PROFILE_BENCHMARK="1"
RUN_NCU="0"
STRICT_MODE="0"

# Official benchmark options
OFFICIAL_DTYPE="fp16"
OFFICIAL_PYTORCH_DTYPE="match"
OFFICIAL_PATH="$HOME/flash-attention"

# Build / ncu
BUILD_DIR="build"
CUDA_ARCH="80"
TORCH_CUDA_ARCH_LIST="8.0"
CUDA_HOME="/usr/local/cuda"
CUDACXX="/usr/local/cuda/bin/nvcc"
NCU_CMD="/usr/local/cuda/bin/ncu"
NCU_SET="full"
NCU_LAUNCH_SKIP=""
NCU_LAUNCH_COUNT=""
NCU_USE_SUDO="1"

# Backward-compatible options accepted by scripts/local/run.sh
# RUN_TARGET="ours"               # all|ours|official|pytorch
# OFFICIAL_SEQ_LENS="4096"
# OFFICIAL_D_HEADS="128"
# OFFICIAL_BATCH_SIZE="16"
# OFFICIAL_N_HEADS="16"
# OFFICIAL_WARMUPS="10"
# OFFICIAL_REPEATS="50"
# OFFICIAL_INPUT_MODE="random"
# OFFICIAL_SEED="1234"
# OFFICIAL_REPLAY_DIR="benchmark/data/replay"
# OFFICIAL_REPLAY_FILE=""
# RUN_BENCHMARK="1"
# REMOTE_ARCH="80"
